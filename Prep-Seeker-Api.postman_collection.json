    {
      "name": "POST /login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "if (response.access_token) {",
              "    pm.environment.set(\"token\", response.access_token);",
              "    console.log(\"Token saved:\", response.access_token);",
              "} else {",
              "    console.log(\"Login failed or no access_token in response.\");",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "disabled": false
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "type": "text",
              "key": "username",
              "value": "admin"
            },
            {
              "type": "text",
              "key": "password",
              "value": "password123"
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "login"
          ]
        },
        "description": "Get access token. Use username: admin, password: password123"
      },
      "response": []
    },
